# Session encryption — generate with: openssl rand -base64 32
NUXT_SESSION_PASSWORD=

# GitHub OAuth App credentials (https://github.com/settings/developers)
NUXT_OAUTH_GITHUB_CLIENT_ID=
NUXT_OAUTH_GITHUB_CLIENT_SECRET=

# Exact GitHub username allowed to access /admin (case-sensitive)
GITHUB_ALLOWED_LOGIN=

# Storage backend: 'local' (default, uses the filesystem) or 'vercel-blob'
STORAGE_DRIVER=local

# Required when STORAGE_DRIVER=vercel-blob (from Vercel project settings > Storage)
BLOB_READ_WRITE_TOKEN=
