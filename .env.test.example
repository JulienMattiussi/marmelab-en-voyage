# Fixed session password for tests — does not need to be secure
NUXT_SESSION_PASSWORD=test-session-password-for-e2e-testing-only

# GitHub OAuth not needed for E2E (tests bypass OAuth via /api/__test-login)
NUXT_OAUTH_GITHUB_CLIENT_ID=test
NUXT_OAUTH_GITHUB_CLIENT_SECRET=test

# Must match the login used in test sessions
GITHUB_ALLOWED_LOGIN=test-user

# Always use local storage for tests
STORAGE_DRIVER=local
